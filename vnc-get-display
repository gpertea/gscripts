#!/bin/bash
SIZE=1820x960
if [[ -n "$1" ]]; then
  SIZE="$1"
fi
#set -e
ps=$(ps x | grep 'X.*[v]nc' | awk '{ print $6 }' | sed s/://)
if [[ -z $ps ]]; then
vncserver -localhost=no -geometry="$SIZE"  -SecurityTypes=VncAuth 2>&1 | \
    sed -n 's/.*display :\([0-9][0-9]*\).*/\1/p'
else 
  echo "$ps"
fi
